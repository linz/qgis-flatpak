{
    "name": "python-owslib",
    "buildsystem": "simple",
    "build-commands": [
        "pip3 install --prefix=/app *dateutil-*",
        "pip3 install --prefix=/app --no-build-isolation pytz-*",
        "pip3 install --prefix=/app pathspec-*",
        "pip3 install --prefix=/app editables-*",
        "pip3 install --prefix=/app pluggy-*",
        "pip3 install --prefix=/app trove_classifiers-*",
        "pip3 install --prefix=/app hatchling-*",
        "pip3 install --prefix=/app urllib3-*",
        "pip3 install --prefix=/app idna-*",
        "pip3 install --prefix=/app --no-build-isolation certifi-*",
        "pip3 install --prefix=/app charset_normalizer-*",
        "pip3 install --prefix=/app requests-*",
        "pip3 install --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"lxml\" --no-build-isolation",
        "pip3 install --prefix=/app --no-build-isolation owslib*"
    ],
